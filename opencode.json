{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "docs/SPEC.md",
    "docs/adr/*.md",
    "docs/architecture/*.md",
    "docs/llm-workflow-handbook.md"
  ],
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "external_directory": "deny"
  },
  "compaction": {
    "auto": true,
    "reserved": 10000
  },
  "formatter": {
    "ktlint": {
      "command": ["./gradlew", "ktlintFormat"],
      "extensions": [".kt", ".kts"]
    }
  }
}
