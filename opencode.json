{
    "$schema": "https://opencode.ai/config.json",
    "instructions": [
        "AGENTS.md",
        "docs/SPEC.md",
        "docs/adr/*.md",
        "docs/architecture/*.md"
    ],
    "shell": "/bin/zsh",
    "share": "manual",
    "autoupdate": "notify",
    "snapshot": true,
    "lsp": true,

    "permission": {
        "*": "allow",
        "edit": "allow",
        "write": "allow",
        "webfetch": "allow",
        "skill": {
            "*": "allow"
        },
        "external_directory": "deny",
        "bash": {
            "pwd": "allow",
            "npx *": "allow",
            "ls *": "allow",
            "find *": "allow",
            "fd *": "allow",
            "rg *": "allow",
            "grep *": "allow",
            "cat *": "allow",
            "sed *": "allow",
            "awk *": "allow",
            "git status*": "allow",
            "git diff*": "allow",
            "git log*": "allow",
            "git show*": "allow",
            "git commit*": "ask",
            "git push*": "ask",
            "./gradlew tasks*": "allow",
            "./gradlew test*": "allow",
            "./gradlew check*": "allow",
            "./gradlew build*": "allow",
            "./gradlew clean build*": "allow",
            "./gradlew ktlintCheck*": "allow",
            "./gradlew ktlintFormat*": "allow",
            "./gradlew bootRun*": "ask",
            "docker ps*": "allow",
            "docker compose ps*": "allow",
            "docker compose logs*": "allow",
            "docker compose up*": "ask",
            "docker compose down*": "ask",
            "kubectl get *": "allow",
            "kubectl describe *": "allow",
            "kubectl logs *": "allow",
            "rm *": "ask",
            "sudo *": "ask",
            "rm -rf *": "deny",
            "rm -fr *": "deny",
            "rm -rf /": "deny",
            "rm -rf .": "deny",
            "mv *": "ask",
            "chmod -R 777": "ask",
            "chown -R": "ask",
            "dd if=*": "ask",
            "mkfs*": "ask",
            "shutdown": "deny",
            "reboot": "deny",
            "killall": "ask",
            "pkill": "allow",
            "curl * | sh": "ask",
            "wget * | sh": "ask",
            "*": "allow"
        }
    },
    "compaction": {
        "auto": true,
        "prune": true,
        "reserved": 12000
    },
    "formatter": {
        "ktlint": {
            "command": [
                "./gradlew",
                "ktlintFormat"
            ],
            "extensions": [
                ".kt",
                ".kts"
            ]
        }
    },
    "watcher": {
        "ignore": [
            "**/.git/**",
            "**/.gradle/**",
            "**/build/**",
            "**/out/**",
            "**/target/**",
            "**/.idea/**",
            "**/.kotlin/**",
            "**/.direnv/**",
            "**/node_modules/**",
            "**/coverage/**",
            "**/dist/**",
            "**/tmp/**",
            "**/*.log"
        ]
    },
    "attachment": {
        "image": {
            "auto_resize": true,
            "max_width": 2000,
            "max_height": 2000,
            "max_base64_bytes": 5242880
        }
    }
}

